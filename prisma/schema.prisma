generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("CLIENT")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[]
  auditLogs AuditLog[]
}

model Client {
  id          String        @id @default(uuid())
  userId      String?
  accountId   String        @unique
  name        String?
  balance     Float         @default(0)
  dailyLimit  Int           @default(10000)
  status      String        @default("ACTIVE")
  apiKey      String?       @unique
  throttleRate Int          @default(10)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User?         @relation(fields: [userId], references: [id])
  messages    Message[]
  transactions Transaction[]
}

model Message {
  id           String      @id @default(uuid())
  clientId     String?
  messageId    String      @unique
  from         String?
  to           String?
  content      String?
  parts        Int         @default(1)
  status       String      @default("PENDING")
  dlrStatus    String?
  errorCode    String?
  submittedAt  DateTime    @default(now())
  deliveredAt  DateTime?
  cost         Float       @default(0)
  smppAccountId String?
  client       Client?     @relation(fields: [clientId], references: [id])
  dlrRecords   DlrRecord[]
}

model DlrRecord {
  id         String   @id @default(uuid())
  messageId  String?
  status     String?
  errorCode  String?
  receivedAt DateTime @default(now())
  details    Json?
  message    Message? @relation(fields: [messageId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  clientId    String?
  type        String?
  amount      Float?
  description String?
  reference   String?
  createdAt   DateTime @default(now())
  client      Client?  @relation(fields: [clientId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String?
  entityType String?
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model PricingRule {
  id          String @id @default(uuid())
  countryCode String
  pricePerMsg Float
  operator    String?
}

model SystemHealth {
  id          String   @id @default(uuid())
  component   String?
  status      String?
  metrics     Json?
  lastChecked DateTime @default(now()) @updatedAt
}
