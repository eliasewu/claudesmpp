# Kannel Build - Final Fixed Version for Debian 12 with Symlink
FROM debian:12-slim AS builder

RUN apt-get update && apt-get install -y \
    build-essential \
    libxml2-dev \
    libmariadb-dev \
    libssl-dev \
    pkg-config \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create symlink for MySQL headers
RUN ln -s /usr/include/mariadb /usr/include/mysql

WORKDIR /build
RUN curl -k -L -o kannel.tar.gz https://kannel.org/download/1.5.0/gateway-1.5.0.tar.gz && \
    tar -xzf kannel.tar.gz && \
    cd gateway-1.5.0 && \
    ./configure \
      --with-mysql=/usr \
      --with-ssl=/usr \
      --enable-ssl \
      --prefix=/usr/local/kannel && \
    make -j2 && \
    make install

FROM debian:12-slim

RUN apt-get update && apt-get install -y \
    libxml2 \
    libmariadb3 \
    mariadb-client \
    openssl \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/kannel /usr/local/kannel

RUN mkdir -p /var/log/kannel /var/spool/kannel /etc/kannel
COPY kannel/*.conf /etc/kannel/

COPY docker/healthcheck-kannel.sh /usr/local/bin/healthcheck-kannel.sh
RUN chmod +x /usr/local/bin/healthcheck-kannel.sh

EXPOSE 13000 13001 13013 2775 2345

CMD ["/usr/local/kannel/sbin/bearerbox", "/etc/kannel/bearerbox.conf"]
